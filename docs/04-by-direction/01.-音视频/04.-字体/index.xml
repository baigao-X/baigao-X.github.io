 &lt;td&gt;半宽&lt;/td&gt;
 &lt;td&gt;全宽&lt;/td&gt;
 &lt;td&gt;是&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;Term&lt;/td&gt;
 &lt;td&gt;是&lt;/td&gt;
 &lt;td&gt;半宽&lt;/td&gt;
 &lt;td&gt;半宽&lt;/td&gt;
 &lt;td&gt;是&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td&gt;Fixed&lt;/td&gt;
 &lt;td&gt;是&lt;/td&gt;
 &lt;td&gt;半宽&lt;/td&gt;
