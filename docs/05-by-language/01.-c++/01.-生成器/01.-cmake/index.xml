<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>Cmake on My Docs</title><link>/docs/05-by-language/01.-c++/01.-%E7%94%9F%E6%88%90%E5%99%A8/01.-cmake/</link><description>Recent content in Cmake on My Docs</description><generator>Hugo</generator><language>zh-CN</language><copyright>Copyright (c) 2020-2026 Baigao</copyright><lastBuildDate>Tue, 17 Mar 2026 00:27:27 +0800</lastBuildDate><atom:link href="/docs/05-by-language/01.-c++/01.-%E7%94%9F%E6%88%90%E5%99%A8/01.-cmake/index.xml" rel="self" type="application/rss+xml"/><item><title>跨平台配置</title><link>/docs/05-by-language/01.-c-/01.-%E7%94%9F%E6%88%90%E5%99%A8/01.-cmake/%E8%B7%A8%E5%B9%B3%E5%8F%B0%E9%85%8D%E7%BD%AE/</link><pubDate>Tue, 17 Mar 2026 00:27:27 +0800</pubDate><guid>/docs/05-by-language/01.-c-/01.-%E7%94%9F%E6%88%90%E5%99%A8/01.-cmake/%E8%B7%A8%E5%B9%B3%E5%8F%B0%E9%85%8D%E7%BD%AE/</guid><description>&lt;h1 id="1-cmake_system_name-变量"&gt;1. CMAKE_SYSTEM_NAME 变量&lt;/h1&gt;
&lt;p&gt;系统变量&lt;/p&gt;



&lt;div class="expressive-code"&gt;
 &lt;figure class="frame not-content"&gt;
 &lt;figcaption class="header"&gt;
 &lt;span class="title"&gt;&lt;/span&gt;
 &lt;/figcaption&gt;
 &lt;div class="highlight"&gt;&lt;pre tabindex="0" class="chroma"&gt;&lt;code class="language-cmake" data-lang="cmake"&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt;&lt;span class="nb"&gt;if&lt;/span&gt; &lt;span class="p"&gt;(&lt;/span&gt;&lt;span class="s"&gt;CMAKE_SYSTEM_NAME&lt;/span&gt; &lt;span class="s"&gt;MATCHES&lt;/span&gt; &lt;span class="s2"&gt;&amp;#34;Windows&amp;#34;&lt;/span&gt;&lt;span class="p"&gt;)&lt;/span&gt;&lt;span class="err"&gt;
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt;&lt;span class="nb"&gt;elseif&lt;/span&gt; &lt;span class="p"&gt;(&lt;/span&gt;&lt;span class="s"&gt;CMAKE_SYSTEM_NAME&lt;/span&gt; &lt;span class="s"&gt;MATCHES&lt;/span&gt; &lt;span class="s2"&gt;&amp;#34;Linux&amp;#34;&lt;/span&gt;&lt;span class="p"&gt;)&lt;/span&gt;&lt;span class="err"&gt;
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt;&lt;span class="nb"&gt;elseif&lt;/span&gt; &lt;span class="p"&gt;(&lt;/span&gt;&lt;span class="s"&gt;CMAKE_SYSTEM_NAME&lt;/span&gt; &lt;span class="s"&gt;MATCHES&lt;/span&gt; &lt;span class="s2"&gt;&amp;#34;Darwin&amp;#34;&lt;/span&gt;&lt;span class="p"&gt;)&lt;/span&gt;&lt;span class="err"&gt;
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt;&lt;span class="nb"&gt;endif&lt;/span&gt;&lt;span class="p"&gt;()&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;
 &lt;/figure&gt;
&lt;/div&gt;
&lt;h1 id="2-关于系统的一些简写变量"&gt;2. 关于系统的一些简写变量&lt;/h1&gt;
&lt;ul&gt;
&lt;li&gt; &lt;code&gt;WIN32&lt;/code&gt; : 32 位 Windows 和 64 位 Windows 都为真&lt;/li&gt;
&lt;li&gt;&lt;code&gt;APPLE&lt;/code&gt; : 对于所有苹果产品（MacOS 或 iOS）都为真&lt;/li&gt;
&lt;li&gt;&lt;code&gt;UNIX&lt;/code&gt;  : 对于所有 Unix 类系统（&lt;code&gt;FreeBSD, Linux, Android, MacOS, iOS&lt;/code&gt;）都为真&lt;/li&gt;
&lt;li&gt;&lt;code&gt;ANDROID&lt;/code&gt; :&lt;/li&gt;
&lt;li&gt;&lt;code&gt;IOS&lt;/code&gt;  :&lt;/li&gt;
&lt;li&gt;&lt;code&gt;MacOs&lt;/code&gt;  :&lt;/li&gt;
&lt;/ul&gt;



&lt;div class="expressive-code"&gt;
 &lt;figure class="frame not-content"&gt;
 &lt;figcaption class="header"&gt;
 &lt;span class="title"&gt;&lt;/span&gt;
 &lt;/figcaption&gt;
 &lt;div class="highlight"&gt;&lt;pre tabindex="0" class="chroma"&gt;&lt;code class="language-cmake" data-lang="cmake"&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt;&lt;span class="nb"&gt;if&lt;/span&gt; &lt;span class="p"&gt;(&lt;/span&gt;&lt;span class="s"&gt;WIN32&lt;/span&gt;&lt;span class="p"&gt;)&lt;/span&gt;&lt;span class="err"&gt;
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt;&lt;span class="nb"&gt;elseif&lt;/span&gt; &lt;span class="p"&gt;(&lt;/span&gt;&lt;span class="s"&gt;UNIX&lt;/span&gt; &lt;span class="s"&gt;AND&lt;/span&gt; &lt;span class="s"&gt;NOT&lt;/span&gt; &lt;span class="s"&gt;APPLE&lt;/span&gt;&lt;span class="p"&gt;)&lt;/span&gt;&lt;span class="err"&gt;
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt;&lt;span class="nb"&gt;elseif&lt;/span&gt; &lt;span class="p"&gt;(&lt;/span&gt;&lt;span class="s"&gt;APPLE&lt;/span&gt;&lt;span class="p"&gt;)&lt;/span&gt;&lt;span class="err"&gt;
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt;&lt;span class="nb"&gt;endif&lt;/span&gt;&lt;span class="p"&gt;()&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;
 &lt;/figure&gt;
&lt;/div&gt;
&lt;h1 id="3-cmake_cxx_compiler_id-变量"&gt;3. CMAKE_CXX_COMPILER_ID 变量&lt;/h1&gt;
&lt;p&gt;编译器&lt;/p&gt;</description></item><item><title>现代Cmake的推荐使用方法</title><link>/docs/05-by-language/01.-c-/01.-%E7%94%9F%E6%88%90%E5%99%A8/01.-cmake/%E7%8E%B0%E4%BB%A3cmake%E7%9A%84%E6%8E%A8%E8%8D%90%E4%BD%BF%E7%94%A8%E6%96%B9%E6%B3%95/</link><pubDate>Tue, 17 Mar 2026 00:27:27 +0800</pubDate><guid>/docs/05-by-language/01.-c-/01.-%E7%94%9F%E6%88%90%E5%99%A8/01.-cmake/%E7%8E%B0%E4%BB%A3cmake%E7%9A%84%E6%8E%A8%E8%8D%90%E4%BD%BF%E7%94%A8%E6%96%B9%E6%B3%95/</guid><description/></item></channel></rss>