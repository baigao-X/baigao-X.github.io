&lt;h2 id="11-采样"&gt;1.1. 采样&lt;/h2&gt;
&lt;ul&gt;
&lt;li&gt;对一个正在运行的程序进行采样：&lt;/li&gt;
&lt;/ul&gt;



&lt;div class="expressive-code"&gt;
 &lt;figure class="frame is-terminal not-content"&gt;
 &lt;figcaption class="header"&gt;
 &lt;span class="title"&gt;&lt;/span&gt;
 &lt;/figcaption&gt;
 &lt;div class="highlight"&gt;&lt;pre tabindex="0" class="chroma"&gt;&lt;code class="language-shell" data-lang="shell"&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt;perf record -p PID -g -- sleep &lt;span class="m"&gt;60&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;
 &lt;/figure&gt;
&lt;/div&gt;
&lt;ul&gt;
&lt;li&gt;全新执行一个进程，并进行采样&lt;/li&gt;
&lt;/ul&gt;



&lt;div class="expressive-code"&gt;
 &lt;figure class="frame is-terminal not-content"&gt;
 &lt;figcaption class="header"&gt;
 &lt;span class="title"&gt;&lt;/span&gt;
 &lt;/figcaption&gt;
 &lt;div class="highlight"&gt;&lt;pre tabindex="0" class="chroma"&gt;&lt;code class="language-shell" data-lang="shell"&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt;perf record -F &lt;span class="m"&gt;99&lt;/span&gt; -g ./test -- sleep &lt;span class="m"&gt;60&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;
 &lt;/figure&gt;
&lt;/div&gt;
&lt;h2 id="12-转换火焰图"&gt;1.2. 转换火焰图&lt;/h2&gt;



&lt;div class="expressive-code"&gt;
 &lt;figure class="frame not-content"&gt;
 &lt;figcaption class="header"&gt;
 &lt;span class="title"&gt;&lt;/span&gt;
 &lt;/figcaption&gt;
 &lt;pre tabindex="0"&gt;&lt;code&gt;//将采样的perf.data 文件
perf script -i perf.data &amp;amp;&amp;gt; perf.unfold

//将采样的perf.data 文件转换成火焰图
// 依赖：https://github.com/brendangregg/FlameGraph.git

./FlameGraph/stackcollapse-perf.pl perf.unfold &amp;amp;&amp;gt; perf.folded

./FlameGraph/flamegraph.pl perf.folded &amp;gt; perf.svg&lt;/code&gt;&lt;/pre&gt;
 &lt;/figure&gt;
&lt;/div&gt;
&lt;h1 id="2"&gt;2.&lt;/h1&gt;</description></item><item><title>Unixbench</title><link>/docs/02-code-better-sleep-better/06.-%E8%B0%83%E8%AF%95%E5%AE%9A%E4%BD%8D/02.-%E6%80%A7%E8%83%BD%E8%B0%83%E4%BC%98/unixbench/</link><pubDate>Tue, 17 Mar 2026 00:27:27 +0800</pubDate><guid>/docs/02-code-better-sleep-better/06.-%E8%B0%83%E8%AF%95%E5%AE%9A%E4%BD%8D/02.-%E6%80%A7%E8%83%BD%E8%B0%83%E4%BC%98/unixbench/</guid><description>&lt;div class="expressive-code"&gt;
 &lt;figure class="frame is-terminal not-content"&gt;
